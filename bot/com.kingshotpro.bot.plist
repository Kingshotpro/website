<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Launchd plist for the KingshotPro player-lookup bot.

  Install (one-time):
    cp bot/com.kingshotpro.bot.plist ~/Library/LaunchAgents/
    launchctl load  ~/Library/LaunchAgents/com.kingshotpro.bot.plist

  Controls:
    launchctl list | grep kingshotpro
    launchctl unload ~/Library/LaunchAgents/com.kingshotpro.bot.plist

  Logs:
    /tmp/bot_server.out  /tmp/bot_server.err

  Notes:
    - Runs uvicorn directly instead of `python3 server.py` so failures
      show up cleanly in stderr.
    - KeepAlive = true → if the process dies, launchd restarts it in ~10s.
    - ThrottleInterval = 10 → minimum delay between relaunch attempts.
    - This does NOT start the cloudflared tunnel. The tunnel has its own
      plist (com.kingshotpro.tunnel.plist) OR get a permanent Fly.io
      URL instead, which is less fragile than a Mac-local tunnel.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.kingshotpro.bot</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/python3</string>
    <string>-m</string>
    <string>uvicorn</string>
    <string>server:app</string>
    <string>--host</string>
    <string>127.0.0.1</string>
    <string>--port</string>
    <string>8080</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/defimagic/Desktop/Hive/KingshotPro/bot</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/Users/defimagic/Library/Python/3.9/bin</string>
    <key>PYTHONPATH</key>
    <string>/Users/defimagic/Desktop/Hive/KingshotPro/bot</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>/tmp/bot_server.out</string>

  <key>StandardErrorPath</key>
  <string>/tmp/bot_server.err</string>
</dict>
</plist>
